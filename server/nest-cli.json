{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/server/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/server/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/server",
  "projects": {
    "accounts": {
      "type": "application",
      "root": "apps/accounts",
      "entryFile": "main",
      "sourceRoot": "apps/accounts/src",
      "compilerOptions": {
        "tsConfigPath": "apps/accounts/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "contacts": {
      "type": "application",
      "root": "apps/contacts",
      "entryFile": "main",
      "sourceRoot": "apps/contacts/src",
      "compilerOptions": {
        "tsConfigPath": "apps/contacts/tsconfig.app.json"
      }
    },
    "deals": {
      "type": "application",
      "root": "apps/deals",
      "entryFile": "main",
      "sourceRoot": "apps/deals/src",
      "compilerOptions": {
        "tsConfigPath": "apps/deals/tsconfig.app.json"
      }
    },
    "leads": {
      "type": "application",
      "root": "apps/leads",
      "entryFile": "main",
      "sourceRoot": "apps/leads/src",
      "compilerOptions": {
        "tsConfigPath": "apps/leads/tsconfig.app.json"
      }
    },
    "opportunities": {
      "type": "application",
      "root": "apps/opportunities",
      "entryFile": "main",
      "sourceRoot": "apps/opportunities/src",
      "compilerOptions": {
        "tsConfigPath": "apps/opportunities/tsconfig.app.json"
      }
    },
    "server": {
      "type": "application",
      "root": "apps/server",
      "entryFile": "main",
      "sourceRoot": "apps/server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/server/tsconfig.app.json"
      }
    },
    "tasks": {
      "type": "application",
      "root": "apps/tasks",
      "entryFile": "main",
      "sourceRoot": "apps/tasks/src",
      "compilerOptions": {
        "tsConfigPath": "apps/tasks/tsconfig.app.json"
      }
    },
    "webhooks": {
      "type": "application",
      "root": "apps/webhooks",
      "entryFile": "main",
      "sourceRoot": "apps/webhooks/src",
      "compilerOptions": {
        "tsConfigPath": "apps/webhooks/tsconfig.app.json"
      }
    }
  }
}